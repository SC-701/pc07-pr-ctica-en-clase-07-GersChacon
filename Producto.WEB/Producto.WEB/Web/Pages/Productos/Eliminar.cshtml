@page
@model Web.Pages.Productos.EliminarModel
@{
    ViewData["Title"] = "Eliminar Producto";
}

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">

        <div class="d-flex align-items-center mb-4">
            <a class="btn btn-ghost btn-sm me-3" asp-page="./Index">← Regresar</a>
            <div>
                <h2 class="mb-0 fw-bold" style="color:var(--danger)">🗑️ Eliminar Producto</h2>
                <small style="color:var(--text-muted)">Esta acción no se puede deshacer</small>
            </div>
        </div>

        @if (Model.ErrorApi != null)
        {
            <div class="alert-dark-danger d-flex align-items-center gap-2 p-3 mb-4">
                <span>⛔</span>
                <div><strong>Error de conexión</strong><br><small>@Model.ErrorApi</small></div>
            </div>
        }
        else if (Model.producto != null)
        {
            <div class="alert-dark-danger d-flex align-items-center gap-2 p-3 mb-4">
                <span>⛔</span>
                <small>Está a punto de eliminar permanentemente este producto del sistema.</small>
            </div>

            <div class="card mb-4">
                <div class="card-header accent-danger">
                    <strong>📦 Producto a eliminar</strong>
                </div>
                <div class="card-body">
                    <h5 class="fw-bold mb-1">@Html.DisplayFor(m => m.producto.Nombre)</h5>
                    <p class="mb-3" style="color:var(--text-muted);font-size:0.88rem">
                        @Html.DisplayFor(m => m.producto.Descripcion)
                    </p>
                    <div class="row g-2">
                        <div class="col-sm-4">
                            <div class="stat-box">
                                <div class="stat-label">Precio</div>
                                <div class="stat-value" style="color:var(--success)">₡@Html.DisplayFor(m => m.producto.Precio)</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="stat-box">
                                <div class="stat-label">Stock</div>
                                <div class="stat-value">@Html.DisplayFor(m => m.producto.Stock) uds</div>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="stat-box">
                                <div class="stat-label">Categoría</div>
                                <div class="stat-value" style="font-size:0.95rem">@Html.DisplayFor(m => m.producto.Categoria)</div>
                            </div>
                        </div>
                    </div>
                    <div class="mt-3" style="font-size:0.8rem;color:var(--text-muted)">
                        🔢 @Html.DisplayFor(m => m.producto.CodigoBarras)
                        &nbsp;·&nbsp;
                        🏷️ @Html.DisplayFor(m => m.producto.SubCategoria)
                    </div>
                </div>
            </div>

            <form method="post">
                <input type="hidden" name="id" value="@Model.producto.Id" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger-custom flex-grow-1">⛔ Confirmar Eliminación</button>
                    <a class="btn btn-ghost" asp-page="./Index">Cancelar</a>
                </div>
            </form>
        }
    </div>
</div>
