@page
@model Web.Pages.Productos.AgregarModel
@{
    ViewData["Title"] = "Agregar Producto";
}

<div class="row justify-content-center">
    <div class="col-xl-6 col-lg-7 col-md-9">

        <div class="d-flex align-items-center mb-4">
            <a class="btn btn-ghost btn-sm me-3" asp-page="./Index">← Regresar</a>
            <div>
                <h2 class="mb-0 fw-bold">Nuevo Producto</h2>
                <small style="color:var(--text-muted)">Complete todos los campos para registrar el producto</small>
            </div>
        </div>

        @if (Model.ErrorApi != null)
        {
            <div class="alert-dark-danger d-flex align-items-center gap-2 p-3 mb-4">
                <span>⛔</span>
                <div><strong>Error al guardar</strong><br><small>@Model.ErrorApi</small></div>
            </div>
        }

        <form method="post">
            <div class="card mb-4">
                <div class="card-header accent-primary">
                    <strong>📦 Información del Producto</strong>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="categorias" class="form-label">Categoría</label>
                            <select asp-for="categoriaSeleccionada" class="form-select" asp-items="Model.categorias" id="categorias" onchange="fetchSubCategorias()">
                                <option value="">— Seleccione una categoría —</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="subcategorias" class="form-label">Subcategoría</label>
                            <select asp-for="producto.IdSubCategoria" class="form-select" asp-items="Model.subcategorias" id="subcategorias">
                                <option value="">— Seleccione una subcategoría —</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label" asp-for="producto.Nombre"></label>
                            <input class="form-control" asp-for="producto.Nombre" placeholder="Nombre del producto">
                            <span class="text-danger small" asp-validation-for="producto.Nombre"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label" asp-for="producto.Descripcion"></label>
                            <textarea class="form-control" asp-for="producto.Descripcion" rows="3" placeholder="Describa el producto..."></textarea>
                            <span class="text-danger small" asp-validation-for="producto.Descripcion"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" asp-for="producto.Precio"></label>
                            <div class="input-group">
                                <span class="input-group-text">₡</span>
                                <input class="form-control" asp-for="producto.Precio" placeholder="0.00">
                            </div>
                            <span class="text-danger small" asp-validation-for="producto.Precio"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" asp-for="producto.Stock"></label>
                            <input class="form-control" asp-for="producto.Stock" placeholder="0">
                            <span class="text-danger small" asp-validation-for="producto.Stock"></span>
                        </div>
                        <div class="col-12">
                            <label class="form-label" asp-for="producto.CodigoBarras"></label>
                            <input class="form-control" asp-for="producto.CodigoBarras" placeholder="Ej: 123456789">
                            <span class="text-danger small" asp-validation-for="producto.CodigoBarras"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-danger mb-3 small" asp-validation-summary="All"></div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary-custom flex-grow-1">✔ Guardar Producto</button>
                <a class="btn btn-ghost" asp-page="./Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        async function fetchSubCategorias() {
            const categoriaId = document.getElementById("categorias").value;
            if (!categoriaId) return;
            try {
                const response = await fetch(`?handler=ObtenerSubCategorias&categoriaId=${categoriaId}`);
                if (!response.ok) throw new Error('Error obteniendo Datos');
                const subcategorias = await response.json();
                const subcategoriasSelect = document.getElementById('subcategorias');
                subcategoriasSelect.innerHTML = '<option value="">— Seleccione una subcategoría —</option>';
                subcategorias.forEach(sc => {
                    const option = document.createElement("option");
                    option.value = sc.id;
                    option.text = sc.nombre;
                    subcategoriasSelect.appendChild(option);
                });
            } catch (error) {
                console.error('Error obteniendo las subcategorías', error);
            }
        }
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
