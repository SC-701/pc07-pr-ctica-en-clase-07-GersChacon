@page
@model Web.Pages.Productos.IndexModel
@{
    ViewData["Title"] = "Productos";
}

@if (Model.ErrorApi != null)
{
    <div class="alert-dark-danger d-flex align-items-center gap-2 p-3 mb-4">
        <span>⛔</span>
        <div>
            <strong>Sin conexión a la API</strong><br>
            <small>@Model.ErrorApi</small>
        </div>
    </div>
}

<div class="page-header">
    <div>
        <h2>📦 Gestión de Productos</h2>
        <small>Administre el inventario de productos del sistema</small>
    </div>
    @if (Model.ErrorApi == null)
    {
        <a class="btn btn-primary-custom" asp-page="./Agregar">＋ Nuevo Producto</a>
    }
</div>

@if (Model.ErrorApi == null)
{
    @if (Model.productos == null || !Model.productos.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">📭</div>
            <h5>Sin productos registrados</h5>
            <p>Agregue su primer producto usando el botón de arriba.</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var producto in Model.productos)
            {
                <div class="col-xl-4 col-md-6">
                    <div class="card h-100">
                        <div class="card-header accent-primary d-flex justify-content-between align-items-center">
                            <span class="fw-bold" style="color:var(--text)">@Html.DisplayFor(m => producto.Nombre)</span>
                            <span class="badge-custom">@Html.DisplayFor(m => producto.Categoria)</span>
                        </div>
                        <div class="card-body py-3">
                            <p class="mb-3" style="color:var(--text-muted);font-size:0.85rem;line-height:1.5">
                                @Html.DisplayFor(m => producto.Descripcion)
                            </p>
                            <div class="row g-2">
                                <div class="col-6">
                                    <div class="stat-box">
                                        <div class="stat-label">Precio</div>
                                        <div class="stat-value" style="color:var(--success)">₡@Html.DisplayFor(m => producto.Precio)</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="stat-box">
                                        <div class="stat-label">Stock</div>
                                        <div class="stat-value">
                                            <span class="@(producto.Stock > 10 ? "badge-custom badge-stock-ok" : "badge-custom badge-stock-low")">
                                                @Html.DisplayFor(m => producto.Stock) uds
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-3" style="font-size:0.8rem;color:var(--text-muted)">
                                🔢 @Html.DisplayFor(m => producto.CodigoBarras)
                                &nbsp;·&nbsp;
                                🏷️ @Html.DisplayFor(m => producto.SubCategoria)
                            </div>
                        </div>
                        <div class="card-footer d-flex gap-2">
                            <a class="btn btn-ghost btn-sm flex-fill" asp-page="./Detalle" asp-route-id="@producto.Id">🔍 Detalle</a>
                            <a class="btn btn-warning-custom btn-sm flex-fill" asp-page="./Editar" asp-route-id="@producto.Id">✏️ Editar</a>
                            <a class="btn btn-danger-custom btn-sm" asp-page="./Eliminar" asp-route-id="@producto.Id">🗑</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
